# =========================================
# Aplicação
# =========================================
# String de conexão usada pelo Prisma (monte a partir dos POSTGRES_* abaixo)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todo-list-api"

# Porta em que a API sobe (opcional, padrão 3000)
PORT=3000

# =========================================
# PostgreSQL (usado pelo docker-compose para provisionar o banco)
# =========================================
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="todo-list-api"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432

# =========================================
# Autenticação (JWT)
# =========================================
# Segredo usado para assinar o token (use uma chave forte e única)
SECRET="your-super-secret-key"
# Tempo de expiração do token (ex.: 1d, 12h, 3600s)
EXPIRES="1d"

# =========================================
# Opcional
# =========================================
# Origem permitida no CORS (sem isso, reflete a origem da requisição)
# CORS_ORIGIN="http://localhost:5173"
